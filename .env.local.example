# Kopier denne filen til .env og fyll inn verdiene fra Lovable Cloud / Supabase.
# IKKE commit .env til Git — den inneholder hemmeligheter.

# Publishable / anon-nøkkel (trygg i klientkode)
SUPABASE_PUBLISHABLE_KEY=""

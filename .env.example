# Kopier denne filen til .env og fyll inn verdiene fra Lovable Cloud / Supabase.
# IKKE commit .env til Git — den inneholder hemmeligheter.

# Klientside (Vite eksponerer kun VITE_-prefiksede variabler i browseren)
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""        # Finn i Supabase Dashboard → Project Settings → General
VITE_SITE_URL=""                   # Produksjonsdomenet, f.eks. https://rytterbakken.no

# Server-only (aldri VITE_-prefix her — eksponeres ikke i klientkoden)
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""     # Kun for server-funksjoner — ALDRI commit

# Resend (e-postsending)
RESEND_API_KEY=""                  # Finn på resend.com → API Keys
RESEND_WEBHOOK_SECRET=""           # Finn på resend.com → Webhooks → din endpoint → Signing secret

# AI (Eir-chat på Min side)
OPENROUTER_API_KEY=""              # Finn på openrouter.ai → API Keys
